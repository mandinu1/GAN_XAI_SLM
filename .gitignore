---

## `.gitignore`

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# VS Code / macOS
.vscode/
.DS_Store

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log

# Model checkpoints
*.pth
*.pt
*.ckpt

# Large outputs
experiments/
runs/
outputs/
results/
checkpoints/
samples/
evaluation/
training_plots/

# Images and generated reports
*.png
*.jpg
*.jpeg
*.pdf
*.npy
*.npz
*.json

# Cache
.cache/
.pytest_cache/
.mypy_cache/

# Hugging Face / Transformers cache
hf_cache/
transformers_cache/

# Environment files / secrets
.env
.env.*
*.env

# OS files
Thumbs.db
